{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["correctedYaml", "findings"],
  "properties": {
    "correctedYaml": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["findingId"],
        "properties": {
          "findingId": { "type": "string" },
          "explanation": { "type": ["string", "null"] },
          "proposedFix": { "type": ["string", "null"] },
          "citation": { "type": ["string", "null"] }
        }
      }
    },
    "designFindings": {
      "type": "array",
      "description": "L5 design-quality + L6 test-basis-adequacy findings (LLM judgment).",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["layer", "summary"],
        "properties": {
          "layer": { "type": "string", "enum": ["L5", "L6"] },
          "severity": { "type": ["string", "null"] },
          "endpoint": { "type": ["string", "null"] },
          "summary": { "type": "string" },
          "explanation": { "type": ["string", "null"] },
          "citation": { "type": ["string", "null"] },
          "evidence": {
            "type": ["object", "null"],
            "description": "Optional pointer to the parsed CODE_API artifact the finding is about, bound deterministically (validated, never fabricated). Omit for spec-wide observations.",
            "additionalProperties": true,
            "properties": {
              "codeSchema": { "type": ["string", "null"] },
              "codeField": { "type": ["string", "null"] },
              "endpoint": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "selfReview": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "confidence": { "type": ["number", "null"] },
        "blindSpots": { "type": "array", "items": { "type": "string" } }
      }
    },
    "disputedFindings": {
      "type": "array",
      "description": "DETERMINISTIC findings the LLM believes are FALSE POSITIVES the CODE_API/SPEC_API evidence contradicts. Veritas keeps each one visible to a human and only moves it out of the automatic release-blocking gate — it is never deleted. findingId must be one sent in DETERMINISTIC_FINDINGS; reason is mandatory.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["findingId", "reason"],
        "properties": {
          "findingId": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
