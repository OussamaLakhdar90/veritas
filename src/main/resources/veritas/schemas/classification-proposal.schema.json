{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["suggestedSeverity", "rationale"],
  "properties": {
    "suggestedSeverity": {
      "type": "string",
      "enum": ["BLOCKER", "CRITICAL", "MAJOR", "MINOR", "INFO"]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  }
}
