{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["feature", "evidence", "content"],
  "properties": {
    "feature": { "type": "string" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["unitId"],
        "properties": {
          "unitId": { "type": "string" },
          "quote": { "type": "string" },
          "gloss": { "type": "string" }
        }
      }
    },
    "content": {}
  }
}
