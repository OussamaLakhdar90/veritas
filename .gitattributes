# Normalize line endings so a Windows checkout doesn't churn every file the agent touches.
# Source/text is stored LF in the repo; binaries are left untouched.
* text=auto eol=lf

*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.properties text eol=lf
*.http   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.sh     text eol=lf

# Windows scripts keep CRLF.
*.cmd    text eol=crlf
*.bat    text eol=crlf

# Binary assets — never normalize.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.jar    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
